{
  "rewrites": [
    {
      "source": "/",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(googlebot|Googlebot|bingbot|Bingbot).*"
        }
      ],
      "destination": "/api/prerender?path="
    },
    {
      "source": "/:path*",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": ".*(googlebot|Googlebot|bingbot|Bingbot).*"
        }
      ],
      "destination": "/api/prerender?path=:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
