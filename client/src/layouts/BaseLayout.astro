---
import '../index.css'

interface Props {
  title?: string
  description?: string
  canonical?: string
  ogImage?: string
  ogType?: string
  keywords?: string
  schema?: Record<string, unknown> | Array<Record<string, unknown>>
}

const SITE = 'https://peopleandstyle.in'

const {
  title = 'Bridal Wear on Rent in Mysuru & Bangalore | People & Style',
  description = "People & Style — Karnataka's premium rental service. Rent bridal lehenga, wedding gown, sherwani & jewellery. Also offering bridal makeup and wedding photography in Mysuru and Bangalore.",
  canonical,
  ogImage = `${SITE}/og-default.jpeg`,
  ogType = 'website',
  keywords = 'bridal wear on rent in Mysuru, bridal wear on rent in Bangalore, bridal lehenga on rent Mysuru, wedding gown rental Mysuru, sherwani on rent Mysuru, bridal jewellery on rent Mysuru, makeup artist Mysuru, wedding photographer Mysuru',
  schema,
} = Astro.props

const canonicalUrl = canonical ?? `${SITE}${Astro.url.pathname}`

const defaultSchema = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'ClothingStore'],
  name: 'People & Style',
  description:
    'Bridal wear rental, jewellery rental, makeup services and wedding photography in Mysuru and Bangalore, Karnataka.',
  url: SITE,
  telephone: '+919187668280',
  email: 'hello@peopleandstyle.in',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Mysuru',
    addressRegion: 'Karnataka',
    addressCountry: 'IN',
  },
  areaServed: [
    { '@type': 'City', name: 'Mysuru' },
    { '@type': 'City', name: 'Bangalore' },
    { '@type': 'State', name: 'Karnataka' },
  ],
  image: `${SITE}/og-default.jpeg`,
  sameAs: [
    'https://www.instagram.com/peopleandstyle.in',
  ],
  geo: {
    '@type': 'GeoCoordinates',
    latitude: '12.2958',
    longitude: '76.6394',
  },
  openingHours: ['Mo-Sa 10:00-19:00', 'Su 11:00-17:00'],
  priceRange: '₹₹',
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Rental & Services',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Bridal Lehenga on Rent in Mysuru' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Bridal Jewellery on Rent in Mysuru' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Bridal Makeup Services Mysuru' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Wedding Photography Mysuru' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Bridal Lehenga on Rent in Bangalore' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Bridal Jewellery on Rent in Bangalore' } },
    ],
  },
}

const activeSchema = schema ?? defaultSchema
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0e0e0e" />
    <link rel="icon" type="image/jpeg" href="/favicon.jpeg" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="People & Style" />

    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="People & Style" />
    <meta property="og:locale" content="en_IN" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Preconnects for fonts, API & images -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://rental-website-6a9i.vercel.app" crossorigin />
    <link rel="preconnect" href="https://ik.imagekit.io" crossorigin />
    <link rel="dns-prefetch" href="https://people-and-style-assets-mumbai.s3.ap-south-1.amazonaws.com" />

    <!-- Fire banners API fetch before React boots so the response is ready or in-flight when Hero renders -->
    <!-- Also preloads the first hero image URL at high priority as soon as the API responds -->
    <script define:vars={{ apiUrl: import.meta.env.VITE_API_URL || 'https://rental-website-6a9i.vercel.app' }}>
      (function () {
        var IK_BASE = 'https://ik.imagekit.io/kayivtq3l/';
        var S3_BASE = 'https://people-and-style-assets-mumbai.s3.ap-south-1.amazonaws.com/';
        var base = (apiUrl || '').replace(/\/+$/, '');
        var device = window.innerWidth < 768 ? 'mobile' : 'desktop';
        var width = device === 'mobile' ? 600 : 1400;

        fetch(base + '/api/banners?type=hero&device=' + device, { credentials: 'omit' })
          .then(function (r) { return r.json(); })
          .then(function (banners) {
            if (!Array.isArray(banners) || !banners.length) return;
            var first = banners.find(function (b) { return b && b.imageUrl; });
            if (!first) return;
            var src = first.imageUrl;
            if (src.startsWith(S3_BASE)) {
              src = IK_BASE + src.slice(S3_BASE.length) + '?tr=w-' + width + ',q-auto,f-auto';
            } else if (src.includes('ik.imagekit.io')) {
              // already an imagekit URL — use as-is
            } else {
              return; // unknown origin, skip preload
            }
            var link = document.createElement('link');
            link.rel = 'preload';
            link.as = 'image';
            link.href = src;
            link.setAttribute('fetchpriority', 'high');
            document.head.appendChild(link);
          })
          .catch(function () {});
      })();
    </script>

    <!-- Structured data -->
    {Array.isArray(activeSchema)
      ? activeSchema.map((s) => (
          <script type="application/ld+json" set:html={JSON.stringify(s)} />
        ))
      : <script type="application/ld+json" set:html={JSON.stringify(activeSchema)} />
    }
  </head>
  <body class="bg-[#0e0e0e]">
    <div id="app-loader" style="position:fixed;inset:0;z-index:9999;background:radial-gradient(circle at top, rgba(168,85,247,0.16), transparent 36%), linear-gradient(180deg, #101010 0%, #0b0b0b 100%);display:flex;align-items:center;justify-content:center;transition:opacity 0.3s ease">
      <div style="display:flex;flex-direction:column;align-items:center;gap:16px;text-align:center">
        <span style="font-family:instrument serif,serif;font-size:1.45rem;color:#ffffff;letter-spacing:0.022em;display:inline-block;will-change:opacity,transform;">People &amp; Style</span>
        <div style="display:flex;align-items:center;justify-content:center;gap:8px;height:18px" aria-hidden="true">
          <span style="width:8px;height:8px;border-radius:999px;background:rgba(255,255,255,0.95);box-shadow:0 0 14px rgba(255,255,255,0.22);animation:loaderDot 1.05s ease-in-out infinite;animation-delay:0s;display:block"></span>
          <span style="width:8px;height:8px;border-radius:999px;background:rgba(255,255,255,0.88);box-shadow:0 0 14px rgba(168,85,247,0.22);animation:loaderDot 1.05s ease-in-out infinite;animation-delay:0.16s;display:block"></span>
          <span style="width:8px;height:8px;border-radius:999px;background:rgba(255,255,255,0.82);box-shadow:0 0 14px rgba(168,85,247,0.18);animation:loaderDot 1.05s ease-in-out infinite;animation-delay:0.32s;display:block"></span>
        </div>
      </div>
    </div>
    <style>@keyframes loaderSpin{to{transform:rotate(360deg)}}@keyframes loaderPulse{0%,100%{transform:scale(0.92);opacity:0.62}50%{transform:scale(1);opacity:1}}@keyframes loaderText{0%{opacity:0;transform:translateY(6px) scale(0.98)}20%{opacity:1;transform:translateY(0) scale(1)}75%{opacity:1;transform:translateY(0) scale(1)}100%{opacity:0;transform:translateY(-4px) scale(0.99)}}@keyframes loaderDot{0%,80%,100%{transform:translateY(0) scale(0.85);opacity:0.45}40%{transform:translateY(-8px) scale(1);opacity:1}}</style>
    <script>
      (function(){
        var el = document.getElementById('app-loader');
        if (!el) return;
        window.__hideLoader = function(){
          el.style.opacity = '0';
          setTimeout(function(){ el.style.display = 'none'; }, 300);
        };
      })();
    </script>
    <slot />
  </body>
</html>
